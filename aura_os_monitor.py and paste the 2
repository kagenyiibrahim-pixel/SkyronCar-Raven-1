class PowerReactorMonitor:
    def __init__(self):
        self.bus_voltage = 800.0  # Target 800V System
        self.recovery_efficiency = 0.92  # 92% Efficiency Target
        self.is_active = True

    def run_diagnostics(self, motor_output, dynamo_input):
        """Calculates energy recovery in the feedback loop."""
        recovery_rate = (dynamo_input / motor_output) if motor_output > 0 else 0
        
        print(f"--- Aura-OS Diagnostic Report ---")
        print(f"Current Recovery Rate: {recovery_rate * 100:.2f}%")
        
        if recovery_rate >= self.recovery_efficiency:
            print("Status: Optimal Energy Independence Achieved.")
        else:
            print("Status: Adjusting Feedback Loop Parameters...")

if __name__ == "__main__":
    monitor = PowerReactorMonitor()
    # Simulate a 500kW output with 460kW recovery
    monitor.run_diagnostics(motor_output=500, dynamo_input=460)
